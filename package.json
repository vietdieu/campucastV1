{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "dev:client": "vite",
    "build": "npm run clean && vite build && node build-server.js",
    "start": "node dist/server.cjs",
    "clean": "node -e \"const fs = require('fs'); fs.rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "lint:hardcoded-colors": "grep -rE '(bg|text|border|ring)-(slate|gray|rose|amber|cyan|emerald|blue|red|indigo|orange)-[0-9]+' src --exclude-dir=foundation --exclude-dir=node_modules",
    "test": "tsx tests/run-all-tests.ts",
    "test:voice": "vitest run tests/voiceRegression.test.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@google-cloud/text-to-speech": "^6.4.1",
    "@google/genai": "^2.4.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "edge-tts": "^1.0.1",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.3.0",
    "html2canvas": "^1.4.1",
    "idb": "^8.0.3",
    "lodash": "^4.18.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "postgres": "^3.4.9",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "uuid": "^14.0.1",
    "vite": "^6.2.3",
    "ws": "^8.21.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "c8": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.1.14",
    "vitest": "^4.1.10"
  }
}
